# Distributed runtime (Phase 6)
# TERMINAL_ROLE=all      — monolith (default): WS + feed + bot engine in one process
# TERMINAL_ROLE=server   — WS + feed only; publishes bar-close events via Redis
# TERMINAL_ROLE=worker   — bot engine only; run via `python worker.py`
#
# REDIS_URL=redis://127.0.0.1:6379/0   — required for server/worker split
# DATABASE_URL=postgresql://user:pass@localhost/trading  — optional; default is SQLite
# SQLITE_DB_PATH=trading-sim.db          — per-instance SQLite file (dual-instance profiles)
# TERMINAL_PROFILE=sim                   — load env.profiles/{profile}.env after repo-root .env
# ALLOW_CUSTOM_STRATEGIES=true         — enable CUSTOM strategy plugins in backend/strategies/
#
# HTTP REST API (Phase 3 — runs alongside WebSocket on server/all roles)
# HTTP_ENABLED=true
# HTTP_HOST=127.0.0.1
# HTTP_PORT=8766
# HTTP_CORS_ORIGINS=*   — or comma-separated origins for production
# HTTP_API_KEY=          — when set, require X-API-Key on all routes except /health
#
# Long-term market bar archive (1m bars in DB, rollup to 1h after retention)
# ARCHIVE_ENABLED=true
# ARCHIVE_RETENTION_1M_DAYS=90
# ARCHIVE_RETENTION_1H_DAYS=1825
# ARCHIVE_FLUSH_INTERVAL=60
# ARCHIVE_ROLLUP_INTERVAL=3600
# ARCHIVE_BACKEND=db          — db | parquet | both (Parquet export optional)
# ARCHIVE_BACKFILL_ON_STARTUP=false — seed market_bars_1m from parquet on boot (off by default; blocks startup)
#
# Simulated feed startup (lazy SBBS — server binds before yfinance warm)
# SIM_INITIAL_CANDLE_BARS=600       — synthetic fallback bars until SBBS loads
# SIM_SBBS_WARM_ON_STARTUP=true     — warm SBBS generators in background after listen
# SIM_SBBS_WARM_PARALLEL=4          — parallel workers for SBBS warm (max 12)
#
# Optional Parquet export (admin POST /api/v1/admin/archive/export)
# ARCHIVE_PARQUET_ENABLED=false
# ARCHIVE_PARQUET_DIR=archive_parquet
#
# Optional sub-minute tick buffer (24h default retention)
# ARCHIVE_TICKS_ENABLED=false
# ARCHIVE_TICK_RETENTION_HOURS=24
# ARCHIVE_TICK_FLUSH_INTERVAL=5
#
# Live bot reconciliation (ambiguous order tracking for eToro at-most-once)
# ALLOW_LIVE_BOTS=false
# BOT_MIN_CANDLES=200
# MARKET_CANDLE_SNAPSHOT_LIMIT=600
# MARKET_CANDLE_SNAPSHOT_MAX=10080
# CALIBRATION_CACHE_TTL_SEC=300
# CALIBRATION_REFRESH_SEC=600
# LOG_JSON=false
#
# Chart Analyst Agent (hybrid rule + optional LLM narrator)
# AGENT_ENABLED=true
# AGENT_MIN_CANDLES=50
# AGENT_LLM_ENABLED=false
# AGENT_LLM_MIN_CONFIDENCE=0.55
# AGENT_LLM_COOLDOWN_SEC=300
# AGENT_LLM_SIM_COOLDOWN_SEC=30
# LLM_PROVIDER=auto          — auto | ollama | openrouter | off
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2:3b
# OLLAMA_MODEL_NARRATOR=llama3.2:3b   — fast model for chart/backtest narration (batch)
# OLLAMA_MODEL_DEEP=                  — optional larger model for deep-reason only; falls back to OLLAMA_MODEL
# AGENT_LLM_PREFER_LOCAL=true
# AGENT_LLM_FALLBACK_CLOUD=false
# OPENROUTER_API_KEY=
# AGENT_LLM_MODEL=openai/gpt-4o-mini
# AGENT_LLM_MODEL_DEEP=               — optional cloud model for deep-reason; falls back to AGENT_LLM_MODEL
# OLLAMA_TIMEOUT_SEC=60
# For thinking models (Qwen3, Gemma 4): use "none" so narratives land in content.
# OLLAMA_REASONING_EFFORT=none
# OLLAMA pull (operator): POST /api/v1/llm/pull {"model":"gemma3:4b"}
# OLLAMA ops status: GET /api/v1/llm/ops
# Model registry: backend/app/services/agent/llm/models.json (tier, recommended, notes)
# BACKTEST_REASONING_MAX_TRADES=20
# LLM reasoning duration ≈ max_trades × OLLAMA_TIMEOUT_SEC; raise frontend
# VITE_BACKTEST_REASONING_TIMEOUT_MS if the UI times out before the server finishes.
#
# Chart vision (on-demand describe — NOT on bar-close hot path)
# AGENT_VISION_ENABLED=false
# AGENT_VISION_MODEL=openai/gpt-4o-mini
# AGENT_VISION_CACHE_SEC=14400
# Requires OPENROUTER_API_KEY. Analyst tab captures chart PNG client-side (1H/4H).
#
# Market scanner (Insights Hub)
# SCANNER_ENABLED=true
#
# Backtest / optimization retention (pruned on server startup)
# OPTIMIZATION_RETENTION_DAYS=30
# BACKTEST_JOB_RETENTION_DAYS=14
#
# WS_HOST=127.0.0.1
# WS_PORT=8765
#
# Interactive Brokers (LIVE_IB — feed-only; execution stays simulated)
# TERMINAL_MODE=LIVE_IB
# IB_HOST=127.0.0.1
# IB_PORT=4002              # IB Gateway paper (4001 live; TWS 7497 paper / 7496 live)
# IB_CLIENT_ID=7            # unique per API connection
# IB_USE_RTH=true           # regular trading hours only for bars
# IB_MARKET_DATA_TYPE=1     # 1=live, 3=delayed
# IB_HIST_DURATION=5 D      # seed history before keepUpToDate stream
# IB_STREAM_STAGGER_SEC=2   # pacing between symbol subscriptions
# IB_PACING_PAUSE_SEC=600
# IB_AUTO_DELAYED_FALLBACK=true
# IB_L1_TICKS_ENABLED=true
# IB_BROADCAST_INTERVAL_SEC=1.5
# IB_OMS_ENABLED=false      # true = route orders to IB (paper port 4002 / live 4001)
# IB_OMS_CLIENT_ID=58       # separate from feed client id
# IB_SMOKE_CLIENT_ID=907   # dedicated id for smoke/integration tests
# Smoke: python scripts/ib_smoke_test.py (requires Gateway/TWS + market data subs)
#
# Massive.com / Polygon.io (LIVE_MASSIVE — feed-only; execution stays simulated)
# TERMINAL_MODE=LIVE_MASSIVE
# MASSIVE_API_KEY=
# MASSIVE_FEED=realtime          # realtime | delayed
# MASSIVE_WS_URL=wss://socket.polygon.io/stocks
# MASSIVE_CRYPTO_WS_URL=wss://socket.polygon.io/crypto
# MASSIVE_REST_URL=https://api.polygon.io
# MASSIVE_HIST_DAYS=5
# MASSIVE_BROADCAST_INTERVAL_SEC=1.5
# MASSIVE_WS_RECONNECT_SEC=5
# MASSIVE_WS_ENABLED=true          # false = REST poll only
# MASSIVE_POLL_FALLBACK=true       # auto REST poll when WS auth fails
# MASSIVE_POLL_INTERVAL_SEC=15
# MASSIVE_QUOTES_ENABLED=true      # Q (stocks) + XQ (crypto) NBBO streams
# MASSIVE_SEED_CONCURRENCY=4       # parallel REST history seed at startup
# HT REST bar depth — chart UI vs bot/TA (per-TF overrides: MASSIVE_HT_LIMIT_1H_ANALYSIS=2000, etc.)
# MASSIVE_HT_LIMIT_CHART=600
# MASSIVE_HT_LIMIT_ANALYSIS=2000
# MASSIVE_HT_FETCH_MAX=50000
# MASSIVE_HT_CACHE_TTL_SEC=300
# MASSIVE_HT_CACHE_MAX_ENTRIES=48
# ALLOW_LIVE_BOTS=true             # paper bots on live quotes + sim OMS (Massive has no broker exec)
# Smoke: python scripts/massive_smoke_test.py
