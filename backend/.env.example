# Distributed runtime (Phase 6)
# TERMINAL_ROLE=all      — monolith (default): WS + feed + bot engine in one process
# TERMINAL_ROLE=server   — WS + feed only; publishes bar-close events via Redis
# TERMINAL_ROLE=worker   — bot engine only; run via `python worker.py`
#
# REDIS_URL=redis://127.0.0.1:6379/0   — required for server/worker split
# DATABASE_URL=postgresql://user:pass@localhost/trading  — optional; default is SQLite
# ALLOW_CUSTOM_STRATEGIES=true         — enable CUSTOM strategy plugins in backend/strategies/
#
# HTTP REST API (Phase 3 — runs alongside WebSocket on server/all roles)
# HTTP_ENABLED=true
# HTTP_HOST=127.0.0.1
# HTTP_PORT=8766
# HTTP_CORS_ORIGINS=*   — or comma-separated origins for production
# HTTP_API_KEY=          — when set, require X-API-Key on all routes except /health
#
# Long-term market bar archive (1m bars in DB, rollup to 1h after retention)
# ARCHIVE_ENABLED=true
# ARCHIVE_RETENTION_1M_DAYS=90
# ARCHIVE_RETENTION_1H_DAYS=1825
# ARCHIVE_FLUSH_INTERVAL=60
# ARCHIVE_ROLLUP_INTERVAL=3600
# ARCHIVE_BACKEND=db          — db | parquet | both (Parquet export optional)
# ARCHIVE_BACKFILL_ON_STARTUP=true  — seed market_bars_1m from parquet on boot
#
# Optional Parquet export (admin POST /api/v1/admin/archive/export)
# ARCHIVE_PARQUET_ENABLED=false
# ARCHIVE_PARQUET_DIR=archive_parquet
#
# Optional sub-minute tick buffer (24h default retention)
# ARCHIVE_TICKS_ENABLED=false
# ARCHIVE_TICK_RETENTION_HOURS=24
# ARCHIVE_TICK_FLUSH_INTERVAL=5
#
# Live bot reconciliation (ambiguous order tracking for eToro at-most-once)
# ALLOW_LIVE_BOTS=false
# BOT_MIN_CANDLES=200
#
# Chart Analyst Agent (hybrid rule + optional LLM narrator)
# AGENT_ENABLED=true
# AGENT_LLM_ENABLED=false
# AGENT_LLM_MIN_CONFIDENCE=0.55
# AGENT_LLM_COOLDOWN_SEC=300
# AGENT_LLM_SIM_COOLDOWN_SEC=30
# LLM_PROVIDER=auto          — auto | ollama | openrouter | off
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2:3b
# AGENT_LLM_PREFER_LOCAL=true
# AGENT_LLM_FALLBACK_CLOUD=false
# OPENROUTER_API_KEY=
# AGENT_LLM_MODEL=openai/gpt-4o-mini
# OLLAMA_TIMEOUT_SEC=60
# For thinking models (Qwen3, Gemma 4): use "none" so narratives land in content.
# OLLAMA_REASONING_EFFORT=none
# BACKTEST_REASONING_MAX_TRADES=20
# LLM reasoning duration ≈ max_trades × OLLAMA_TIMEOUT_SEC; raise frontend
# VITE_BACKTEST_REASONING_TIMEOUT_MS if the UI times out before the server finishes.
#
# WS_HOST=127.0.0.1
# WS_PORT=8765
