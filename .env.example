# Copy to `.env` in the repo root before `docker compose up`.
# Docker Compose reads this file automatically for variable substitution.

# ─── Host ports (change if these are already in use on your machine) ───────
FRONTEND_PORT=8080
BACKEND_HTTP_PORT=8766
BACKEND_WS_PORT=8765
POSTGRES_PORT=5432

# Redis is only started with the `distributed` profile (see below).
REDIS_PORT=6379

# ─── Postgres (internal service credentials) ─────────────────────────────────
POSTGRES_USER=trading
POSTGRES_PASSWORD=trading
POSTGRES_DB=trading

# ─── Backend runtime ─────────────────────────────────────────────────────────
# `all` = single process (default, simplest). `server` = WS/feed only (use with distributed profile).
TERMINAL_ROLE=all

# Dual-instance profiles (sim + IB side by side) — set by scripts/start-*.ps1:
# TERMINAL_PROFILE=sim   loads env.profiles/sim.env (ports 8765/8766)
# TERMINAL_PROFILE=ib    loads env.profiles/ib.env   (ports 8775/8776)
# See env.profiles/README.md

# Optional server/worker split — also starts Redis + worker:
# COMPOSE_PROFILES=distributed
# TERMINAL_ROLE=server
# REDIS_URL=redis://redis:6379/0

# Uncomment to require an API key on HTTP routes (except /health):
# HTTP_API_KEY=change-me

# ─── Optional data & AI integrations ─────────────────────────────────────────
# Finnhub sentiment (equities — company news + news-sentiment API)
# FINNHUB_API_KEY=
# FINNHUB_API_URL=https://finnhub.io/api/v1

# Strategy advisor (LLM/heuristic param suggestions + shadow backtest compare)
# STRATEGY_ADVISOR_ENABLED=true
# STRATEGY_ADVISOR_DEFAULT_DAYS=30
