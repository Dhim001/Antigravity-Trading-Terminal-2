# Leave empty in dev — Vite proxies /api and /health to the backend (:8766).
# Set for production builds served separately from the API, e.g.:
# VITE_HTTP_BASE_URL=http://127.0.0.1:8766
VITE_HTTP_BASE_URL=

# WebSocket URL (must be reachable from the browser)
VITE_WS_URL=ws://127.0.0.1:8765

# Optional — must match backend HTTP_API_KEY when auth is enabled
# VITE_HTTP_API_KEY=
