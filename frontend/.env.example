# Leave empty in dev — Vite proxies /api and /health to the backend (:8766).
# Set for production builds served separately from the API, e.g.:
# VITE_HTTP_BASE_URL=http://127.0.0.1:8766
VITE_HTTP_BASE_URL=

# WebSocket URL (must be reachable from the browser)
VITE_WS_URL=ws://127.0.0.1:8765

# Optional — must match backend HTTP_API_KEY when auth is enabled
# VITE_HTTP_API_KEY=

# Backtest client wait timeout (ms) before showing a timeout toast in the UI.
# Single-symbol runs use this value; portfolio runs use max(10 min, this × symbol count).
# VITE_BACKTEST_TIMEOUT_MS=120000
# CHART_AGENT meta-label walk-forward (default 10 min; +45s per day above 7):
# VITE_BACKTEST_META_LABEL_WF_TIMEOUT_MS=600000
# With LLM reasoning enabled (default 15 min; +30s per day above 7):
# VITE_BACKTEST_REASONING_TIMEOUT_MS=900000

# Operator mode — reveals System Admin controls (build-time and/or backend OPERATOR_MODE).
# VITE_OPERATOR_MODE=true
