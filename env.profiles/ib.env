# Interactive Brokers feed-only profile — second instance (ports 8775/8776, UI :5174)
# Requires IB Gateway/TWS on IB_HOST:IB_PORT (paper Gateway default 4002).
# Launched via:  scripts/start-ib.ps1  or  TERMINAL_PROFILE=ib python main.py

TERMINAL_MODE=LIVE_IB
TERMINAL_ROLE=all

WS_PORT=8775
HTTP_PORT=8776

SQLITE_DB_PATH=trading-ib.db

IB_HOST=127.0.0.1
IB_PORT=4002
IB_CLIENT_ID=8
IB_USE_RTH=true
IB_MARKET_DATA_TYPE=1
IB_HIST_DURATION=5 D
IB_STREAM_STAGGER_SEC=2

# Live bots stay off unless explicitly enabled in repo-root .env
ALLOW_LIVE_BOTS=false

# Phase 2 feed resilience (defaults shown)
# IB_PACING_PAUSE_SEC=600
# IB_AUTO_DELAYED_FALLBACK=true
# IB_L1_TICKS_ENABLED=true
# IB_BROADCAST_INTERVAL_SEC=1.5   # WS market_update cadence for LIVE_IB UI

# Phase 4 execution (paper Gateway 4002 / live 4001) - off by default
# IB_OMS_ENABLED=true
# IB_OMS_CLIENT_ID=58
# IB_READ_ONLY_API=false
