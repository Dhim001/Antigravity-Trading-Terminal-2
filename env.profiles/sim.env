# Simulated terminal profile — default dev instance (ports 8765/8766, UI :5173)
# Launched via:  scripts/start-sim.ps1  or  TERMINAL_PROFILE=sim python main.py

TERMINAL_MODE=SIMULATED
TERMINAL_ROLE=all

WS_PORT=8765
HTTP_PORT=8766

# Separate SQLite file so sim portfolio state is not mixed with IB instance.
SQLITE_DB_PATH=trading-sim.db

SIM_SBBS_WARM_ON_STARTUP=true
