# Massive (Polygon.io) stocks + crypto feed — third instance (ports 8785/8786, UI :5175)
# Requires MASSIVE_API_KEY in repo-root .env (shared secret).
# Launched via:  scripts/start-massive.ps1  or  TERMINAL_PROFILE=massive python main.py

TERMINAL_MODE=LIVE_MASSIVE
TERMINAL_ROLE=all

WS_PORT=8785
HTTP_PORT=8786

SQLITE_DB_PATH=trading-massive.db

# realtime | delayed (sets default WS host when MASSIVE_WS_URL unset)
# Stocks: delayed WS (AM bars). Crypto: realtime WS (XA/XT/XQ) — split URLs below.
MASSIVE_FEED=realtime
MASSIVE_WS_URL=wss://delayed.massive.com/stocks
# MASSIVE_CRYPTO_WS_URL=wss://socket.massive.com/crypto
# MASSIVE_REST_URL=https://api.polygon.io
MASSIVE_HIST_DAYS=5
# MASSIVE_BROADCAST_INTERVAL_SEC=1.5
# MASSIVE_WS_ENABLED=true
# MASSIVE_POLL_FALLBACK=true
# MASSIVE_POLL_INTERVAL_SEC=15
# MASSIVE_QUOTES_ENABLED=true
# MASSIVE_SEED_CONCURRENCY=4

# Higher-timeframe REST depth (chart UI vs bot/TA analysis). Per-TF overrides optional:
# MASSIVE_HT_LIMIT_CHART=600
# MASSIVE_HT_LIMIT_ANALYSIS=2000
# MASSIVE_HT_FETCH_MAX=50000
# MASSIVE_HT_LIMIT_5M_CHART=1500
# MASSIVE_HT_LIMIT_5M_ANALYSIS=3000
# MASSIVE_HT_LIMIT_15M_CHART=1200
# MASSIVE_HT_LIMIT_15M_ANALYSIS=2500
# MASSIVE_HT_LIMIT_1H_CHART=600
# MASSIVE_HT_LIMIT_1H_ANALYSIS=2000
# MASSIVE_HT_LIMIT_4H_CHART=800
# MASSIVE_HT_LIMIT_4H_ANALYSIS=1500
# MASSIVE_HT_LIMIT_1D_CHART=500
# MASSIVE_HT_LIMIT_1D_ANALYSIS=1250

# Bots on Massive use SimulatedOMSService (feed-only — no broker execution).
# Paper bots run against live Massive quotes with simulated fills.
ALLOW_LIVE_BOTS=true
